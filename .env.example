# ============================================================
# Progetto Armadio — Environment Variables Template
# Copia questo file in .env e compila i valori reali
# ============================================================

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Replicate (Stable Diffusion + IDM-VTON) ---
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database ---
# SQLite (sviluppo locale)
DATABASE_URL=sqlite:///./armadio.db
# PostgreSQL (produzione) — decommenta e adatta:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/armadio_db

# --- Storage ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# --- Sicurezza ---
SECRET_KEY=cambia-questa-stringa-con-un-valore-segreto-lungo-e-casuale
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---
# Lista di origini separate da virgola
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
